<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/teacher_commissions/db" VERSION="20240101"
    COMMENT="XMLDB file for local_teacher_commissions plugin"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">
  <TABLES>

    <!--
      local_tc_settings
      Stores commission percentage per teacher (userid=0 = global default).
      One row per teacher; the global default has userid=0.
    -->
    <TABLE NAME="local_tc_settings" COMMENT="Teacher commission settings (userid=0 = global default)">
      <FIELDS>
        <FIELD NAME="id"                 TYPE="int"    LENGTH="10" NOTNULL="true"  SEQUENCE="true"/>
        <FIELD NAME="userid"             TYPE="int"    LENGTH="10" NOTNULL="true"  DEFAULT="0"    COMMENT="Teacher user ID; 0 = global default"/>
        <FIELD NAME="commission_percent" TYPE="number" LENGTH="5"  DECIMALS="2"    NOTNULL="true" DEFAULT="0.00"/>
        <FIELD NAME="createdby"          TYPE="int"    LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="timecreated"        TYPE="int"    LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="timemodified"       TYPE="int"    LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="userid_uniq" TYPE="unique" FIELDS="userid"/>
      </KEYS>
    </TABLE>

    <!--
      local_tc_transactions
      One row per commission event (= one paid enrollment).
      status: pending | paid
    -->
    <TABLE NAME="local_tc_transactions" COMMENT="Commission transactions linked to paid enrollments">
      <FIELDS>
        <FIELD NAME="id"                 TYPE="int"    LENGTH="10" NOTNULL="true"  SEQUENCE="true"/>
        <FIELD NAME="teacherid"          TYPE="int"    LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="courseid"           TYPE="int"    LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="studentid"          TYPE="int"    LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="enrolid"            TYPE="int"    LENGTH="10" NOTNULL="true"  DEFAULT="0"    COMMENT="mdl_enrol.id"/>
        <FIELD NAME="userenrolmentid"    TYPE="int"    LENGTH="10" NOTNULL="true"  DEFAULT="0"    COMMENT="mdl_user_enrolments.id"/>
        <FIELD NAME="saleamount"         TYPE="number" LENGTH="10" DECIMALS="2"    NOTNULL="true" DEFAULT="0.00"/>
        <FIELD NAME="commission_percent" TYPE="number" LENGTH="5"  DECIMALS="2"    NOTNULL="true" DEFAULT="0.00"/>
        <FIELD NAME="commissionamount"   TYPE="number" LENGTH="10" DECIMALS="2"    NOTNULL="true" DEFAULT="0.00"/>
        <FIELD NAME="currency"           TYPE="char"   LENGTH="3"  NOTNULL="true"  DEFAULT="USD"/>
        <FIELD NAME="status"             TYPE="char"   LENGTH="20" NOTNULL="true"  DEFAULT="pending" COMMENT="pending|paid"/>
        <FIELD NAME="payoutid"           TYPE="int"    LENGTH="10" NOTNULL="false"                COMMENT="FK to local_tc_payouts.id when paid"/>
        <FIELD NAME="notes"              TYPE="text"   NOTNULL="false"/>
        <FIELD NAME="timecreated"        TYPE="int"    LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="timemodified"       TYPE="int"    LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="idx_teacherid"       UNIQUE="false" FIELDS="teacherid"/>
        <INDEX NAME="idx_courseid"        UNIQUE="false" FIELDS="courseid"/>
        <INDEX NAME="idx_studentid"       UNIQUE="false" FIELDS="studentid"/>
        <INDEX NAME="idx_status"          UNIQUE="false" FIELDS="status"/>
        <INDEX NAME="idx_timecreated"     UNIQUE="false" FIELDS="timecreated"/>
        <INDEX NAME="idx_userenrolmentid" UNIQUE="true"  FIELDS="userenrolmentid" COMMENT="Prevent duplicate commission for same enrollment"/>
      </INDEXES>
    </TABLE>

    <!--
      local_tc_payouts
      One row per payout processed by an admin.
    -->
    <TABLE NAME="local_tc_payouts" COMMENT="Commission payout records">
      <FIELDS>
        <FIELD NAME="id"          TYPE="int"    LENGTH="10" NOTNULL="true"  SEQUENCE="true"/>
        <FIELD NAME="teacherid"   TYPE="int"    LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="amount"      TYPE="number" LENGTH="10" DECIMALS="2"    NOTNULL="true" DEFAULT="0.00"/>
        <FIELD NAME="currency"    TYPE="char"   LENGTH="3"  NOTNULL="true"  DEFAULT="USD"/>
        <FIELD NAME="notes"        TYPE="text"   NOTNULL="false"/>
        <FIELD NAME="receipt_file" TYPE="char"  LENGTH="255" NOTNULL="false"/>
        <FIELD NAME="adminid"     TYPE="int"    LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int"    LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="idx_teacherid"   UNIQUE="false" FIELDS="teacherid"/>
        <INDEX NAME="idx_timecreated" UNIQUE="false" FIELDS="timecreated"/>
      </INDEXES>
    </TABLE>

  </TABLES>
</XMLDB>
