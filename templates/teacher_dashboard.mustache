<div class="local-tc-teacher-dashboard">

    <h2>{{# str}} teacher_dashboard_title, local_teacher_commissions {{/ str}}</h2>

    <div class="row mt-3">

        <div class="col-md-4 mb-3">
            <div class="card border-primary">
                <div class="card-body text-center">
                    <h5 class="card-title text-primary">
                        {{# str}} my_courses, local_teacher_commissions {{/ str}}
                    </h5>
                    <p class="card-text display-4">{{courses_owned}}</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card border-info">
                <div class="card-body text-center">
                    <h5 class="card-title text-info">
                        {{# str}} my_paid_enrollments, local_teacher_commissions {{/ str}}
                    </h5>
                    <p class="card-text display-4">{{paid_enrollments}}</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card border-secondary">
                <div class="card-body text-center">
                    <h5 class="card-title text-secondary">
                        {{# str}} commission_percent, local_teacher_commissions {{/ str}}
                    </h5>
                    <p class="card-text display-4">{{commission_percent}}%</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card bg-light">
                <div class="card-body text-center">
                    <h5 class="card-title">
                        {{# str}} my_total_sales, local_teacher_commissions {{/ str}}
                    </h5>
                    <p class="card-text h3">{{total_sales}} {{currency}}</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card bg-success text-white">
                <div class="card-body text-center">
                    <h5 class="card-title">
                        {{# str}} my_earned_commissions, local_teacher_commissions {{/ str}}
                    </h5>
                    <p class="card-text h3">{{earned}} {{currency}}</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card bg-info text-white">
                <div class="card-body text-center">
                    <h5 class="card-title">
                        {{# str}} my_paid_commissions, local_teacher_commissions {{/ str}}
                    </h5>
                    <p class="card-text h3">{{paid}} {{currency}}</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card bg-warning">
                <div class="card-body text-center">
                    <h5 class="card-title">
                        {{# str}} my_outstanding_balance, local_teacher_commissions {{/ str}}
                    </h5>
                    <p class="card-text h3 fw-bold">{{balance}} {{currency}}</p>
                </div>
            </div>
        </div>

    </div>

    <div class="mt-3">
        <a href="{{{url_ledger}}}" class="btn btn-primary">
            {{# str}} view_full_statement, local_teacher_commissions {{/ str}}
        </a>
    </div>

</div>
